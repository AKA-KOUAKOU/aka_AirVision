# ──────────────────────────────────────────────────────────────────────────────
# AirVision Backend – Environment Variables
# Copy this file to .env and fill in the real values.
# DO NOT commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# JSON Web Token secret key – change to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# JWT token expiry (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ── Database (future) ──────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/airvision

# ── Stripe (future) ───────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all)
# CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:3000
